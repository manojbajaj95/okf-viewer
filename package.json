{
  "name": "okf-viewer",
  "version": "0.2.0",
  "description": "Browse an Open Knowledge Format (OKF) bundle via a local CLI and Next.js viewer",
  "license": "MIT",
  "type": "module",
  "bin": {
    "okf-viewer": "./bin/okf-viewer.mjs"
  },
  "files": [
    "bin",
    "lib/cli-args.mjs",
    ".next/standalone"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build && node ./scripts/postbuild.mjs",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "okf-viewer": "node ./bin/okf-viewer.mjs"
  },
  "engines": {
    "node": ">=22.14.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/manojbajaj95/okf-viewer.git"
  },
  "bugs": {
    "url": "https://github.com/manojbajaj95/okf-viewer/issues"
  },
  "homepage": "https://github.com/manojbajaj95/okf-viewer#readme",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "gray-matter": "^4.0.3",
    "next": "16.2.10",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
